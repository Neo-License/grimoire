{
  "name": "@kiwi-data/grimoire",
  "version": "0.1.0",
  "description": "Gherkin + MADR spec-driven development for AI coding assistants",
  "type": "module",
  "bin": {
    "grimoire": "./bin/grimoire.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist/",
    "bin/",
    "templates/",
    "skills/",
    "AGENTS.md",
    "README.md"
  ],
  "keywords": [
    "gherkin",
    "bdd",
    "madr",
    "adr",
    "spec-driven",
    "ai",
    "claude",
    "codex",
    "cursor"
  ],
  "author": "Kiwi Data",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "chalk": "^5.5.0",
    "yaml": "^2.8.0",
    "fast-glob": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0"
  }
}
